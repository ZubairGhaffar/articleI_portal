<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-10">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h3 class="card-title mb-0">My Subscriptions</h3>
          <span class="badge bg-primary"><%= @subscribed_to_users.count %> authors</span>
        </div>
        <div class="card-body">
          <% if @subscribed_to_users.any? %>
            <div class="row">
              <% @subscribed_to_users.each do |user| %>
                <div class="col-md-6 mb-3">
                  <div class="card">
                    <div class="card-body">
                      <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                          <% if user.avatar.attached? %>
                            <%= image_tag user.avatar, class: "rounded-circle", style: "width: 50px; height: 50px; object-fit: cover;" %>
                          <% else %>
                            <div class="bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                              <i class="fas fa-user text-secondary"></i>
                            </div>
                          <% end %>
                        </div>
                        <div class="flex-grow-1 ms-3">
                          <h6 class="mb-0"><%= link_to user.name, public_profile_user_path(user) %></h6>
                          <small class="text-muted">
                            <%= user.articles.published.count %> articles • 
                            <%= user.subscribers.count %> subscribers
                          </small>
                        </div>
                        <div class="flex-shrink-0">
                          <%= button_to "Unsubscribe", 
                                user_subscription_path(user, current_user.subscriptions.find_by(subscribed_to: user)), 
                                method: :delete, 
                                class: "btn btn-outline-danger btn-sm",
                                data: { confirm: "Unsubscribe from #{user.name}?" } %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-4">
              <i class="fas fa-users fa-3x text-muted mb-3"></i>
              <h5 class="text-muted">You haven't subscribed to any authors yet.</h5>
              <p class="text-muted">Discover authors and subscribe to get updates when they publish new articles.</p>
              <%= link_to "Browse Articles", articles_path, class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>