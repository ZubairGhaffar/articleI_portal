<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">User Profile</h3>
        <% if user_signed_in? && current_user != @user %>
          <div>
            <% if current_user.subscribed_to?(@user) %>
              <%= button_to "Unsubscribe", user_subscription_path(@user, current_user.subscriptions.find_by(subscribed_to: @user)), 
                  method: :delete, 
                  class: "btn btn-outline-danger btn-sm",
                  form: { class: "d-inline" } %>
            <% else %>
              <%= button_to "Subscribe", user_subscriptions_path(@user), 
                  method: :post, 
                  class: "btn btn-primary btn-sm",
                  form: { class: "d-inline" } %>
            <% end %>
          </div>
        <% end %>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-4 text-center">
            <% if @user.avatar.attached? %>
              <%= image_tag @user.avatar, class: "img-fluid rounded-circle mb-3", style: "width: 150px; height: 150px; object-fit: cover;" %>
            <% else %>
              <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 150px; height: 150px;">
                <i class="fas fa-user fa-3x text-secondary"></i>
              </div>
            <% end %>
            
            <!-- Subscription stats -->
            <div class="mt-3">
              <div class="d-flex justify-content-around">
                <div class="text-center">
                  <div class="h5 mb-0"><%= @user.subscribers.count %></div>
                  <small class="text-muted">Subscribers</small>
                </div>
                <div class="text-center">
                  <div class="h5 mb-0"><%= @user.subscribed_to_users.count %></div>
                  <small class="text-muted">Subscribing</small>
                </div>
              </div>
            </div>
          </div>
          
          <div class="col-md-8">
            <div class="row mb-3">
              <div class="col-sm-4">
                <strong>Name:</strong>
              </div>
              <div class="col-sm-8">
                <%= @user.name %>
              </div>
            </div>
            
            <div class="row mb-3">
              <div class="col-sm-4">
                <strong>Member since:</strong>
              </div>
              <div class="col-sm-8">
                <%= @user.created_at.strftime("%B %d, %Y") %>
              </div>
            </div>
            
            <div class="row mb-3">
              <div class="col-sm-4">
                <strong>Articles written:</strong>
              </div>
              <div class="col-sm-8">
                <%= @user.articles.published.count %>
              </div>
            </div>

            <% if user_signed_in? && current_user.subscribed_to?(@user) %>
              <div class="alert alert-info mt-3">
                <small>
                  <i class="fas fa-bell"></i>
                  You are subscribed to this author. You'll receive updates when they publish new articles.
                </small>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    
    <!-- User's Published Articles -->
    <div class="card mt-4">
      <div class="card-header">
        <h5 class="card-title mb-0"><%= @user.name %>'s Published Articles</h5>
      </div>
      <div class="card-body">
        <% if @articles.any? %>
          <div class="list-group">
            <% @articles.each do |article| %>
              <div class="list-group-item">
                <div class="d-flex w-100 justify-content-between">
                  <h6 class="mb-1"><%= link_to article.title, article %></h6>
                  <small class="text-muted"><%= article.created_at.strftime("%b %d, %Y") %></small>
                </div>
                <p class="mb-1 text-muted"><%= truncate(article.content, length: 150) %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-muted">This user hasn't published any articles yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>