<!-- app/views/devise/registrations/new.html.erb -->
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card shadow">
        <div class="card-header bg-primary text-white">
          <h2 class="card-title mb-0 text-center">Create Your Account</h2>
        </div>
        
        <div class="card-body p-4">
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { multipart: true, class: "needs-validation" }) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <!-- Name Field -->
            <div class="mb-3">
              <%= f.label :name, class: "form-label fw-bold" %>
              <%= f.text_field :name, 
                    autofocus: true, 
                    required: true,
                    class: "form-control form-control-lg",
                    placeholder: "Enter your full name" %>
            </div>

            <!-- Email Field -->
            <div class="mb-3">
              <%= f.label :email, class: "form-label fw-bold" %>
              <%= f.email_field :email, 
                    autocomplete: "email", 
                    required: true,
                    class: "form-control form-control-lg",
                    placeholder: "Enter your email address" %>
            </div>

            <!-- Phone Number Field -->
            <div class="mb-3">
              <%= f.label :phone_number, class: "form-label fw-bold" %>
              <%= f.telephone_field :phone_number, 
                    required: true,
                    class: "form-control form-control-lg",
                    placeholder: "Enter your phone number" %>
            </div>

            <!-- Avatar Field -->
            <div class="mb-3">
              <%= f.label :avatar, class: "form-label fw-bold" %>
              <%= f.file_field :avatar, 
                    class: "form-control form-control-lg" %>
              <div class="form-text">Upload a profile picture (optional)</div>
            </div>

            <!-- Password Field -->
            <div class="mb-3">
              <%= f.label :password, class: "form-label fw-bold" %>
              <%= f.password_field :password, 
                    autocomplete: "new-password",
                    class: "form-control form-control-lg",
                    placeholder: "Create a password" %>
              <% if @minimum_password_length %>
                <div class="form-text">
                  <i class="fas fa-info-circle"></i> Minimum <%= @minimum_password_length %> characters
                </div>
              <% end %>
            </div>

            <!-- Password Confirmation Field -->
            <div class="mb-4">
              <%= f.label :password_confirmation, class: "form-label fw-bold" %>
              <%= f.password_field :password_confirmation, 
                    autocomplete: "new-password",
                    class: "form-control form-control-lg",
                    placeholder: "Confirm your password" %>
            </div>

            <!-- Submit Button -->
            <div class="d-grid">
              <%= f.submit "Create Account", 
                    class: "btn btn-primary btn-lg fw-bold" %>
            </div>
          <% end %>

          <hr class="my-4">

          <!-- Additional Links -->
          <div class="text-center">
            <p class="mb-2">Already have an account?</p>
            <%= link_to "Sign in to your account", new_session_path(resource_name), 
                  class: "btn btn-outline-primary" %>
          </div>
          
          <div class="text-center mt-3">
            <%= link_to "Forgot your password?", new_password_path(resource_name), 
                  class: "text-decoration-none" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>