<!-- app/views/devise/registrations/edit.html.erb -->
<div class="edit-profile-container">
  <div class="edit-profile-card">
    <h2 class="edit-profile-title">Edit Profile</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, multipart: true, class: "edit-profile-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <!-- Avatar Section -->
      <div class="form-section">
        <div class="field">
          <%= f.label :avatar, class: "field-label" %>
          <div class="avatar-upload">
            <div class="avatar-preview">
              <% if resource.avatar.attached? %>
                <%= image_tag resource.avatar, class: "avatar-current" %>
              <% else %>
                <div class="avatar-placeholder">
                  <i class="fas fa-user"></i>
                </div>
              <% end %>
            </div>
            <%= f.file_field :avatar, class: "file-input", id: "avatar-upload" %>
            <label for="avatar-upload" class="file-input-label">
              <i class="fas fa-camera"></i>
              Choose Avatar
            </label>
          </div>
        </div>
      </div>

      <!-- Personal Information -->
      <div class="form-section">
        <h3 class="section-title">Personal Information</h3>
        
        <div class="field">
          <%= f.label :name, class: "field-label" %>
          <%= f.text_field :name, class: "text-input", placeholder: "Enter your full name" %>
        </div>

        <div class="field">
          <%= f.label :phone_number, class: "field-label" %>
          <%= f.telephone_field :phone_number, class: "text-input", placeholder: "Enter your phone number" %>
        </div>

        <div class="field">
          <%= f.label :email, class: "field-label" %>
          <%= f.email_field :email, autocomplete: "email", class: "text-input", placeholder: "Enter your email address" %>
        </div>
      </div>

      <!-- Password Section -->
      <div class="form-section">
        <h3 class="section-title">Change Password</h3>
        <p class="section-description">Leave password fields blank if you don't want to change it</p>

        <div class="field">
          <%= f.label :password, class: "field-label" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "text-input", placeholder: "New password" %>
          <% if @minimum_password_length %>
            <span class="help-text"><%= @minimum_password_length %> characters minimum</span>
          <% end %>
        </div>

        <div class="field">
          <%= f.label :password_confirmation, class: "field-label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "text-input", placeholder: "Confirm new password" %>
        </div>
      </div>

      <!-- Current Password -->
      <div class="form-section">
        <div class="field">
          <%= f.label :current_password, class: "field-label" %>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "text-input", placeholder: "Enter current password to confirm changes" %>
          <span class="help-text">We need your current password to confirm your changes</span>
        </div>
      </div>

      <div class="actions">
        <%= f.submit "Update Profile", class: "btn-primary" %>
        <%= link_to "Back", :back, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>

  <!-- Account Deletion Section -->
  <div class="danger-zone-card">
    <h3 class="danger-zone-title">
      <i class="fas fa-exclamation-triangle"></i>
      Danger Zone
    </h3>
    
    <div class="danger-zone-content">
      <p class="warning-text">Deleting your account will permanently remove all your data, articles, and comments. This action cannot be undone.</p>
      
      <%= button_to registration_path(resource_name), 
            method: :delete, 
            data: { confirm: "Are you absolutely sure? This will permanently delete your account and all associated data!" }, 
            class: "btn-danger" do %>
        <i class="fas fa-trash-alt"></i>
        Delete My Account
      <% end %>
    </div>
  </div>
</div>

<style>
.edit-profile-container {
  max-width: 600px;
  margin: 2rem auto;
  padding: 0 1rem;
}

.edit-profile-card {
  background: white;
  border-radius: 12px;
  box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
  padding: 2rem;
  margin-bottom: 2rem;
}

.edit-profile-title {
  color: #2d3748;
  font-size: 1.75rem;
  font-weight: 700;
  margin-bottom: 2rem;
  text-align: center;
}

.form-section {
  margin-bottom: 2rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid #e2e8f0;
}

.section-title {
  color: #4a5568;
  font-size: 1.25rem;
  font-weight: 600;
  margin-bottom: 1rem;
}

.section-description {
  color: #718096;
  font-size: 0.875rem;
  margin-bottom: 1rem;
}

.field {
  margin-bottom: 1.5rem;
}

.field-label {
  display: block;
  color: #4a5568;
  font-weight: 500;
  margin-bottom: 0.5rem;
  font-size: 0.875rem;
}

.text-input {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 2px solid #e2e8f0;
  border-radius: 8px;
  font-size: 1rem;
  transition: all 0.2s;
  background: white;
}

.text-input:focus {
  outline: none;
  border-color: #4299e1;
  box-shadow: 0 0 0 3px rgba(66, 153, 225, 0.1);
}

.help-text {
  display: block;
  color: #718096;
  font-size: 0.75rem;
  margin-top: 0.25rem;
}

/* Avatar Upload Styles */
.avatar-upload {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.avatar-preview {
  flex-shrink: 0;
}

.avatar-current {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid #e2e8f0;
}

.avatar-placeholder {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: #edf2f7;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3px dashed #cbd5e0;
  color: #a0aec0;
  font-size: 1.5rem;
}

.file-input {
  display: none;
}

.file-input-label {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  background: #f7fafc;
  border: 2px dashed #cbd5e0;
  border-radius: 8px;
  color: #4a5568;
  cursor: pointer;
  transition: all 0.2s;
  font-size: 0.875rem;
  font-weight: 500;
}

.file-input-label:hover {
  background: #edf2f7;
  border-color: #a0aec0;
}

/* Button Styles */
.actions {
  display: flex;
  gap: 1rem;
  justify-content: flex-end;
  margin-top: 2rem;
}

.btn-primary {
  background: #4299e1;
  color: white;
  padding: 0.75rem 2rem;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
  text-decoration: none;
  display: inline-block;
}

.btn-primary:hover {
  background: #3182ce;
}

.btn-secondary {
  background: #e2e8f0;
  color: #4a5568;
  padding: 0.75rem 2rem;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
  text-decoration: none;
  display: inline-block;
  text-align: center;
}

.btn-secondary:hover {
  background: #cbd5e0;
}

/* Danger Zone Styles */
.danger-zone-card {
  background: white;
  border-radius: 12px;
  box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
  padding: 2rem;
  border-left: 4px solid #e53e3e;
}

.danger-zone-title {
  color: #e53e3e;
  font-size: 1.25rem;
  font-weight: 600;
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.danger-zone-content {
  color: #4a5568;
}

.warning-text {
  margin-bottom: 1.5rem;
  line-height: 1.5;
}

.btn-danger {
  background: #e53e3e;
  color: white;
  padding: 0.75rem 1.5rem;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.btn-danger:hover {
  background: #c53030;
}

/* Responsive Design */
@media (max-width: 640px) {
  .edit-profile-container {
    margin: 1rem auto;
    padding: 0 0.5rem;
  }
  
  .edit-profile-card {
    padding: 1.5rem;
  }
  
  .avatar-upload {
    flex-direction: column;
    align-items: flex-start;
  }
  
  .actions {
    flex-direction: column;
  }
  
  .btn-primary,
  .btn-secondary {
    width: 100%;
    text-align: center;
  }
}

/* Pending Confirmation Alert */
.alert-info {
  background: #bee3f8;
  border: 1px solid #90cdf4;
  color: #2c5282;
  padding: 1rem;
  border-radius: 8px;
  margin-bottom: 1.5rem;
}
</style>