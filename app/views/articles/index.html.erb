<div class="row">
  <!-- LEFT COLUMN -->
  <div class="col-md-8">
    <!-- Search Bar -->
    <div class="card search-card text-white mb-4">
      <div class="card-body">
        <%= form_with url: articles_path, method: :get, local: true, class: "search-form" do |form| %>
          <div class="input-group flex-nowrap flex-md-row flex-column gap-2">
            <%= form.text_field :search, 
                  value: params[:search],
                  placeholder: "Search articles by title or content...", 
                  class: "form-control form-control-lg",
                  aria: { label: "Search articles" } %>

            <div class="d-flex gap-2">
              <%= form.submit "Search", class: "btn btn-light btn-lg w-100 w-md-auto" %>
              <% if params[:search].present? %>
                <%= link_to "Clear", articles_path, class: "btn btn-outline-light btn-lg w-100 w-md-auto" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Search Results Info -->
    <% if params[:search].present? %>
      <div class="alert alert-info mb-4">
        <h5 class="alert-heading">
          <i class="fas fa-search"></i> Search Results
        </h5>
        <p class="mb-0">
          Found <strong><%= @articles.total_count %></strong> article(s) matching "<strong><%= params[:search] %></strong>"
          <%= link_to "View all articles", articles_path, class: "alert-link float-end" %>
        </p>
      </div>
    <% end %>

    <h1 class="mb-4">
      <% if params[:search].present? %>
        Search Results
      <% else %>
        Latest Articles
      <% end %>
    </h1>

    <% if @articles.any? %>
      <% @articles.each do |article| %>
        <div class="card article-card mb-5 shadow-sm">
          <div class="card-body p-4">
            <div class="row align-items-start">
              <!-- Article Text -->
              <div class="col-md-8">
                <h4 class="card-title mb-3">
                  <%= link_to article.title, article, class: "article-title-link" %>
                </h4>
                <p class="card-text article-excerpt mb-4"><%= article.excerpt %></p>

                <div class="article-meta d-flex justify-content-between align-items-center mt-4 pt-3">
                  <div class="author-info">
                    <small class="text-muted">
                      <i class="fas fa-user"></i> 
                      By <%= link_to article.user.name, user_profile_path(article.user), class: "text-decoration-none" %> • 
                      <i class="fas fa-clock"></i> <%= time_ago_in_words(article.created_at) %> ago
                    </small>
                  </div>
                  <div class="engagement-info">
                    <span class="badge bg-light text-dark px-3 py-2">
                      <i class="fas fa-comments"></i> <%= article.comments.count %> comments
                    </span>
                  </div>
                </div>
              </div>

              <!-- Article Image -->
              <div class="col-md-4">
                <% if article.images.attached? %>
                  <div class="article-image-container">
                    <%= image_tag article.images.first, class: "article-image img-fluid rounded" %>
                  </div>
                <% else %>
                  <div class="article-image-placeholder bg-light rounded d-flex align-items-center justify-content-center">
                    <i class="fas fa-newspaper text-muted fa-3x"></i>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <div class="d-flex justify-content-center mt-5">
        <%= paginate @articles %>
      </div>
    <% else %>
      <div class="card shadow-sm mb-4">
        <div class="card-body text-center p-5">
          <i class="fas fa-search fa-3x text-muted mb-3"></i>
          <h3 class="text-muted">
            <% if params[:search].present? %>
              No articles found matching "<%= params[:search] %>"
            <% else %>
              No articles published yet
            <% end %>
          </h3>
          <% if params[:search].present? %>
            <p class="text-muted">Try different search terms or <%= link_to "view all articles", articles_path %></p>
          <% elsif user_signed_in? %>
            <p class="text-muted">Be the first to <%= link_to "write an article", new_article_path %></p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- RIGHT SIDEBAR -->
  <div class="col-md-4">
    <% if user_signed_in? %>
      <div class="card shadow-sm mb-4">
        <div class="card-body text-center p-4">
          <h4 class="card-title mb-3">Welcome back!</h4>
          <p class="card-text mb-4">Ready to share your thoughts with our community?</p>
          <%= link_to "Write New Article", new_article_path, class: "btn btn-primary btn-lg w-100" %>
        </div>
      </div>
    <% else %>
      <div class="card shadow-sm mb-4">
        <div class="card-body text-center p-4">
          <h4 class="card-title mb-3">Join our community</h4>
          <p class="card-text mb-4">Sign up to write articles and join discussions.</p>
          <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-success btn-lg w-100" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
/* === Search Bar === */
.search-card {
  border: none;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}
.search-card .card-body {
  padding: 1.5rem;
}
.search-form .form-control {
  border: none;
  border-radius: 8px;
  font-size: 1.1rem;
  padding: 15px 20px;
}
.search-form .btn {
  border-radius: 8px;
  font-weight: 600;
}

/* Responsive: Stack inputs on mobile */
@media (max-width: 767px) {
  .search-form .input-group {
    flex-direction: column !important;
    gap: 0.75rem;
  }
  .search-form .btn {
    width: 100% !important;
  }
}

/* === Article Styles === */
.article-card {
  transition: transform 0.2s;
  border: 1px solid #eaeaea;
}
.article-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 12px rgba(0,0,0,0.15) !important;
}
.article-title-link {
  color: #2c3e50;
  text-decoration: none;
  font-weight: 700;
}
.article-title-link:hover {
  color: #3498db;
  text-decoration: underline;
}
.article-excerpt {
  color: #555;
  line-height: 1.7;
}
.article-image-container {
  height: 200px;
  overflow: hidden;
}
.article-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}
.article-card:hover .article-image {
  transform: scale(1.05);
}

@media (max-width: 768px) {
  .article-card .row {
    flex-direction: column;
  }
  .article-image-container {
    height: 180px;
    margin-top: 1rem;
  }
}
</style>
